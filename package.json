{
  "name": "@dan-nachmany/i18n",
  "version": "0.1.1",
  "description": "Standalone i18n with auto key generation, pluggable storage (local/S3), and an LLM-powered translation CLI.",
  "keywords": [
    "i18n",
    "internationalization",
    "translation",
    "gemini",
    "s3",
    "cloudflare-r2"
  ],
  "license": "MIT",
  "author": "dan-nachmany",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "i18n-translate": "dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run clean && npm run build:lib && npm run build:cli && chmod +x dist/cli/index.js",
    "build:lib": "tsup src/index.ts --format cjs,esm --dts --sourcemap --out-dir dist",
    "build:cli": "tsup src/cli/index.ts --format cjs --sourcemap --out-dir dist/cli",
    "dev": "tsup src/index.ts src/cli/index.ts --format cjs,esm --dts --sourcemap --out-dir dist --watch",
    "clean": "rm -rf dist coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "translate": "ts-node src/cli/index.ts",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run lint && npm test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danbjnbh1/i18n.git"
  },
  "homepage": "https://github.com/danbjnbh1/i18n#readme",
  "bugs": {
    "url": "https://github.com/danbjnbh1/i18n/issues"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/credential-providers": "^3.1031.0",
    "@google/generative-ai": "^0.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.10.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.2.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
