# Translation CLI
GEMINI_API_KEY=
I18N_PROJECT=app
I18N_SOURCE_LOCALE=en
I18N_STORAGE=local                # local | s3
LOCALES_DIR=./locales
I18N_RATE_LIMIT_MS=200
LOG_LEVEL=info                    # debug | info | warn | error

# S3-compatible storage (only when I18N_STORAGE=s3)
S3_BUCKET=
S3_ENDPOINT=                      # e.g. https://accountid.r2.cloudflarestorage.com
S3_REGION=auto                    # "auto" for Cloudflare R2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
