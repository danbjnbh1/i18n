# Required for Gemini translation CLI
GEMINI_API_KEY=

# Required for S3 storage
S3_BUCKET=
S3_ENDPOINT=          # e.g. https://accountid.r2.cloudflarestorage.com
S3_REGION=auto        # use "auto" for Cloudflare R2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Translator CLI config
I18N_PROJECT=app
LOCALES_DIR=./locales
